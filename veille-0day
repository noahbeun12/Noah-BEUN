<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Veille Technologique — Les failles 0-Day</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">

<style>
  :root {
    --cream: #F5F0E8;
    --black: #0D0D0D;
    --red: #D93025;
    --grey: #8A8070;
    --border: 2px solid var(--black);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; font-size: 16px; }

  body {
    background: var(--cream);
    color: var(--black);
    font-family: 'DM Mono', monospace;
    cursor: crosshair;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.4;
  }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--cream); }
  ::-webkit-scrollbar-thumb { background: var(--black); }

  /* ─── NAV ─── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.2rem 3rem;
    background: var(--cream);
    border-bottom: var(--border);
  }

  .nav-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem;
    letter-spacing: 0.1em;
    color: var(--black);
    text-decoration: none;
  }

  .nav-back {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--black);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    transition: color 0.2s;
  }

  .nav-back:hover { color: var(--red); }

  /* ─── HERO ─── */
  .page-hero {
    min-height: 40vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 8rem 3rem 4rem;
    border-bottom: var(--border);
  }

  .page-tag {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--grey);
    margin-bottom: 1rem;
  }

  .page-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 9vw, 8rem);
    line-height: 0.9;
    color: var(--black);
    margin-bottom: 1.5rem;
  }

  .page-title span { color: var(--red); }

  .page-desc {
    font-family: 'Instrument Serif', serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--grey);
    max-width: 600px;
    line-height: 1.6;
  }

  /* ─── SECTION ─── */
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 2rem;
    padding: 2.5rem 3rem;
    border-bottom: var(--border);
  }

  .section-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    color: var(--red);
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
    letter-spacing: 0.02em;
    color: var(--black);
  }

  /* ─── DEFINITION ─── */
  .definition-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: var(--border);
  }

  .definition-text {
    padding: 4rem 3rem;
    border-right: var(--border);
  }

  .definition-text p {
    font-size: 0.85rem;
    line-height: 1.9;
    color: var(--grey);
    margin-bottom: 1.2rem;
  }

  .definition-text p strong { color: var(--black); font-weight: 500; }

  .definition-stats {
    padding: 4rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    justify-content: center;
  }

  .stat-item {
    border-left: 3px solid var(--red);
    padding-left: 1.5rem;
  }

  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3rem;
    color: var(--black);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--grey);
    margin-top: 0.3rem;
  }

  /* ─── ARTICLES ─── */
  .articles-list {
    border-bottom: var(--border);
  }

  .article-row {
    display: grid;
    grid-template-columns: 160px 1fr 200px 120px;
    align-items: center;
    gap: 2rem;
    padding: 2rem 3rem;
    border-bottom: var(--border);
    transition: background 0.2s;
    cursor: default;
  }

  .article-row:last-child { border-bottom: none; }
  .article-row:hover { background: var(--black); }
  .article-row:hover .art-date,
  .article-row:hover .art-title,
  .article-row:hover .art-source,
  .article-row:hover .art-tag { color: var(--cream); }

  .art-date {
    font-size: 0.65rem;
    color: var(--grey);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .art-title {
    font-size: 0.85rem;
    color: var(--black);
    line-height: 1.5;
    transition: color 0.2s;
  }

  .art-source {
    font-size: 0.65rem;
    color: var(--grey);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: color 0.2s;
    text-align: right;
  }

  .art-tag {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--red);
    border: 1px solid var(--red);
    padding: 0.3rem 0.7rem;
    text-align: center;
    transition: color 0.2s, border-color 0.2s;
  }

  .article-row:hover .art-tag { border-color: var(--cream); }

  /* ─── OUTILS ─── */
  .outils-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-bottom: var(--border);
  }

  .outil-card {
    padding: 3rem;
    border-right: var(--border);
    border-bottom: var(--border);
    transition: background 0.2s;
  }

  .outil-card:nth-child(3n) { border-right: none; }
  .outil-card:hover { background: var(--black); }
  .outil-card:hover .outil-name,
  .outil-card:hover .outil-desc { color: var(--cream); }

  .outil-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 1rem;
  }

  .outil-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    color: var(--black);
    letter-spacing: 0.03em;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }

  .outil-desc {
    font-size: 0.75rem;
    color: var(--grey);
    line-height: 1.7;
    transition: color 0.2s;
  }

  /* ─── FOOTER ─── */
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 3rem;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--grey);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    nav { padding: 1rem 1.5rem; }
    .page-hero { padding: 7rem 1.5rem 3rem; }
    .definition-block { grid-template-columns: 1fr; }
    .definition-text { border-right: none; border-bottom: var(--border); padding: 3rem 1.5rem; }
    .definition-stats { padding: 3rem 1.5rem; }
    .section-header { padding: 2rem 1.5rem; }
    .article-row { grid-template-columns: 1fr; gap: 0.5rem; padding: 1.5rem; }
    .art-source, .art-tag { text-align: left; }
    .outils-grid { grid-template-columns: 1fr; }
    .outil-card { border-right: none; }
    footer { padding: 1.2rem 1.5rem; flex-direction: column; gap: 0.5rem; text-align: center; }
  }
</style>
</head>
